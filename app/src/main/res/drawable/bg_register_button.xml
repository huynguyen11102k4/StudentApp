<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape>
            <solid android:color="@color/register_primary_disabled" />
            <corners android:radius="@dimen/register_input_radius" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/register_primary_pressed" />
            <corners android:radius="@dimen/register_input_radius" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/register_primary" />
            <corners android:radius="@dimen/register_input_radius" />
        </shape>
    </item>
</selector>
