<?xml version="1.0" encoding="utf-8"?>
<!-- Surface variant with soft inner shadow for depth -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <solid android:color="@color/surface_container" />
            <corners android:radius="@dimen/corner_large" />
        </shape>
    </item>
    <item android:top="1dp">
        <shape>
            <solid android:color="#0A000000" />
            <corners
                android:bottomLeftRadius="@dimen/corner_large"
                android:bottomRightRadius="@dimen/corner_large" />
        </shape>
    </item>
</layer-list>
