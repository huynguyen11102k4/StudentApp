<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_chevron_left"
        app:navigationIconTint="@color/on_primary"
        app:title="@string/appeal_detail_title"
        app:titleTextColor="@color/on_primary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="@dimen/spacing_16"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/chipStatus"
                style="@style/Text_Label_Medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_review"
                android:paddingHorizontal="@dimen/spacing_16"
                android:paddingVertical="@dimen/spacing_6"
                android:textColor="@color/status_review_text" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_16"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/student_card_radius"
                app:cardElevation="@dimen/elevation_level2"
                app:contentPadding="@dimen/card_padding"
                app:strokeColor="@color/divider_soft"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Text_Label_Medium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/appeal_detail_student_info" />

                    <TextView
                        android:id="@+id/tvStudentName"
                        style="@style/Text_Body_Large"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_8" />

                    <TextView
                        android:id="@+id/tvStudentCode"
                        style="@style/Text_Body_Small"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_4" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_12"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/student_card_radius"
                app:cardElevation="@dimen/elevation_level2"
                app:contentPadding="@dimen/card_padding"
                app:strokeColor="@color/divider_soft"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Text_Label_Medium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/appeal_detail_exam_info" />

                    <TextView
                        android:id="@+id/tvExamName"
                        style="@style/Text_Body_Large"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_8" />

                    <TextView
                        android:id="@+id/tvSubject"
                        style="@style/Text_Body_Small"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_4" />

                    <TextView
                        android:id="@+id/tvOldScore"
                        style="@style/Text_Headline_Small"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_8" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_12"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/student_card_radius"
                app:cardElevation="@dimen/elevation_level2"
                app:contentPadding="@dimen/card_padding"
                app:strokeColor="@color/divider_soft"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Text_Label_Medium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/appeal_detail_reason" />

                    <TextView
                        android:id="@+id/tvReason"
                        style="@style/Text_Body_Medium"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_8" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAppealItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_12"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/student_card_radius"
                app:cardElevation="@dimen/elevation_level2"
                app:contentPadding="@dimen/card_padding"
                app:strokeColor="@color/divider_soft"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Text_Label_Medium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/appeal_detail_detected_info" />

                    <TextView
                        android:id="@+id/tvDetectedInfo"
                        style="@style/Text_Body_Medium"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_8" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProcessedImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_12"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/student_card_radius"
                app:cardElevation="@dimen/elevation_level2"
                app:contentPadding="@dimen/card_padding"
                app:strokeColor="@color/divider_soft"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Text_Label_Medium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/appeal_detail_processed_image" />

                    <ImageView
                        android:id="@+id/ivProcessedImage"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:layout_marginTop="@dimen/spacing_12"
                        android:adjustViewBounds="true"
                        android:background="@color/surface_variant"
                        android:contentDescription="@string/appeal_detail_processed_image"
                        android:scaleType="centerCrop" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvCreatedAt"
                style="@style/Text_Body_Small"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_16" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackToAppeals"
                style="@style/Student.SecondaryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_24"
                android:text="@string/appeal_detail_back_to_list"
                android:textAllCaps="false" />
        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
