<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/register_background"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingHorizontal="@dimen/register_screen_padding">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="@dimen/register_header_top"
        android:paddingBottom="@dimen/spacing_32">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/common_back"
            android:padding="@dimen/spacing_10"
            android:src="@drawable/ic_chevron_left"
            app:tint="@color/register_text_primary" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_28"
            android:includeFontPadding="false"
            android:lineSpacingExtra="2dp"
            android:text="@string/register_title"
            android:textColor="@color/register_text_primary"
            android:textSize="@dimen/register_title_size"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_10"
            android:lineSpacingExtra="3dp"
            android:text="@string/register_subtitle"
            android:textColor="@color/register_text_secondary"
            android:textSize="@dimen/register_subtitle_size" />

        <LinearLayout
            android:id="@+id/registerFormContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_36"
            android:orientation="vertical">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilFullName"
                style="@style/Register.InputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:startIconDrawable="@drawable/ic_user">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFullName"
                    style="@style/Register.EditText"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/register_input_height"
                    android:hint="@string/register_full_name_hint"
                    android:inputType="textPersonName"
                    android:maxLines="1"
                    android:paddingStart="@dimen/spacing_4"
                    android:paddingEnd="@dimen/spacing_16" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilEmail"
                style="@style/Register.InputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/register_input_gap"
                app:startIconDrawable="@drawable/ic_email">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    style="@style/Register.EditText"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/register_input_height"
                    android:hint="@string/register_email_hint"
                    android:inputType="textEmailAddress"
                    android:maxLines="1"
                    android:paddingStart="@dimen/spacing_4"
                    android:paddingEnd="@dimen/spacing_16" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilStudentCode"
                style="@style/Register.InputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/register_input_gap"
                app:startIconDrawable="@drawable/ic_badge">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etStudentCode"
                    style="@style/Register.EditText"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/register_input_height"
                    android:hint="@string/register_student_code_hint"
                    android:digits="0123456789"
                    android:inputType="number"
                    android:maxLines="1"
                    android:paddingStart="@dimen/spacing_4"
                    android:paddingEnd="@dimen/spacing_16" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilDateOfBirth"
                style="@style/Register.InputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/register_input_gap"
                app:startIconDrawable="@drawable/ic_assignment">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDateOfBirth"
                    style="@style/Register.EditText"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/register_input_height"
                    android:focusable="false"
                    android:clickable="true"
                    android:hint="@string/profile_dob_hint"
                    android:inputType="date"
                    android:maxLines="1"
                    android:paddingStart="@dimen/spacing_4"
                    android:paddingEnd="@dimen/spacing_16" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPassword"
                style="@style/Register.InputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/register_input_gap"
                app:endIconMode="password_toggle"
                app:startIconDrawable="@drawable/ic_lock">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    style="@style/Register.EditText"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/register_input_height"
                    android:hint="@string/register_password_hint"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:paddingStart="@dimen/spacing_4"
                    android:paddingEnd="@dimen/spacing_16" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilConfirmPassword"
                style="@style/Register.InputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/register_input_gap"
                app:endIconMode="password_toggle"
                app:startIconDrawable="@drawable/ic_lock">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etConfirmPassword"
                    style="@style/Register.EditText"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/register_input_height"
                    android:hint="@string/register_confirm_password_hint"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:paddingStart="@dimen/spacing_4"
                    android:paddingEnd="@dimen/spacing_16" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegister"
                style="@style/Register.PrimaryButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/register_button_height"
                android:layout_marginTop="@dimen/spacing_28"
                android:text="@string/register_button" />

            <TextView
                android:id="@+id/btnLoginLink"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_12"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:paddingHorizontal="@dimen/spacing_12"
                android:text="@string/register_login_prompt"
                android:textColor="@color/register_primary"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/registerOtpContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_36"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="@string/register_otp_title"
                android:textColor="@color/register_text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvOtpSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_8"
                android:lineSpacingExtra="3dp"
                android:text="@string/register_otp_subtitle"
                android:textColor="@color/register_text_secondary"
                android:textSize="15sp" />

            <LinearLayout
                android:id="@+id/otpContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_24"
                android:gravity="center"
                android:orientation="horizontal" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerifyOtp"
                style="@style/Register.PrimaryButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/register_button_height"
                android:layout_marginTop="@dimen/spacing_24"
                android:text="@string/register_verify_otp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResendOtp"
                style="@style/Button_Text"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_12"
                android:text="@string/register_resend_otp"
                android:textColor="@color/register_primary" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/spacing_16"
            android:indeterminateTint="@color/register_primary"
            android:visibility="gone" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
