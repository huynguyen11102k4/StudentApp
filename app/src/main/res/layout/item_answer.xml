<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="@dimen/spacing_16"
    android:paddingStart="@dimen/spacing_16"
    android:paddingEnd="@dimen/spacing_16">

    <TextView
        android:id="@+id/tvQuestionNo"
        android:layout_width="@dimen/spacing_40"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="1"
        android:textColor="@color/primary"
        android:textSize="@dimen/text_size_title_medium"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_12"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvStudentAnswer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HS: D -> DA: D"
            style="@style/Text_Body_Medium" />

        <ImageView
            android:id="@+id/ivStatusIcon"
            android:layout_width="@dimen/icon_size_medium"
            android:layout_height="@dimen/icon_size_medium"
            android:layout_marginStart="@dimen/spacing_8"
            android:src="@drawable/ic_check"
            android:tint="@color/success" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEditAnswer"
        style="@style/Button_Text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/smart_review_edit_answer"
        android:textAllCaps="false"
        android:textSize="@dimen/text_size_caption" />
</LinearLayout>