<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="@dimen/spacing_24">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:contentDescription="@string/submission_end_content_description"
            android:src="@drawable/ic_check"
            app:tint="@color/primary" />

        <TextView
            style="@style/Text_Headline_Medium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_20"
            android:gravity="center"
            android:text="@string/submission_end_title"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <TextView
            style="@style/Text_Body_Medium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_8"
            android:gravity="center"
            android:text="@string/submission_end_description"
            android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/tvSyncStatus"
            style="@style/Text_Label_Large"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_16"
            android:gravity="center"
            android:textColor="@color/primary"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnResults"
            style="@style/Student.PrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_large"
            android:layout_marginTop="@dimen/spacing_32"
            android:text="@string/submission_end_results"
            app:icon="@drawable/ic_assignment" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHome"
            style="@style/Student.SecondaryButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_large"
            android:layout_marginTop="@dimen/spacing_12"
            android:text="@string/submission_end_home" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
