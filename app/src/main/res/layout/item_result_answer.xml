<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_8"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="@dimen/corner_large"
    app:cardElevation="@dimen/elevation_level0"
    app:contentPadding="@dimen/spacing_12"
    app:strokeColor="@color/outline_variant"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvQuestion"
            style="@style/Text_Label_Large"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/tvStatus"
            app:layout_constraintEnd_toStartOf="@id/tvStatus"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvStatus" />

        <TextView
            android:id="@+id/tvStatus"
            style="@style/Text_Label_Medium"
            android:layout_width="72dp"
            android:layout_height="30dp"
            android:background="@drawable/bg_answer_status_neutral"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/answerRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_12"
            android:baselineAligned="false"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvStatus">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvStudentAnswerLabel"
                    style="@style/Text_Label_Small"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/result_answer_student_label"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvStudentAnswer"
                    style="@style/Text_Title_Medium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_4"
                    android:background="@drawable/bg_answer_value"
                    android:gravity="center"
                    android:minHeight="40dp"
                    android:paddingStart="@dimen/spacing_8"
                    android:paddingTop="@dimen/spacing_8"
                    android:paddingEnd="@dimen/spacing_8"
                    android:paddingBottom="@dimen/spacing_8"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_8"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvCorrectAnswerLabel"
                    style="@style/Text_Label_Small"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/result_answer_correct_label"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvCorrectAnswer"
                    style="@style/Text_Title_Medium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_4"
                    android:background="@drawable/bg_answer_value"
                    android:gravity="center"
                    android:minHeight="40dp"
                    android:paddingStart="@dimen/spacing_8"
                    android:paddingTop="@dimen/spacing_8"
                    android:paddingEnd="@dimen/spacing_8"
                    android:paddingBottom="@dimen/spacing_8"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
