<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_8"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="@dimen/corner_large"
    app:cardElevation="@dimen/elevation_level0"
    app:contentPadding="@dimen/spacing_12"
    app:strokeColor="@color/outline_variant"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvQuestion"
            style="@style/Text_Label_Large"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/tvStatus"
            app:layout_constraintEnd_toStartOf="@id/tvStatus"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvStatus" />

        <TextView
            android:id="@+id/tvStatus"
            style="@style/Text_Label_Medium"
            android:layout_width="72dp"
            android:layout_height="30dp"
            android:background="@drawable/bg_answer_status_neutral"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvStudentAnswerLabel"
            style="@style/Text_Label_Small"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_12"
            android:text="@string/result_answer_student_label"
            android:textColor="@color/text_secondary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvStatus" />

        <TextView
            android:id="@+id/tvCorrectAnswerLabel"
            style="@style/Text_Label_Small"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_8"
            android:text="@string/result_answer_correct_label"
            android:textColor="@color/text_secondary"
            app:layout_constraintBaseline_toBaselineOf="@id/tvStudentAnswerLabel"
            app:layout_constraintStart_toEndOf="@id/tvStudentAnswer" />

        <TextView
            android:id="@+id/tvStudentAnswer"
            style="@style/Text_Title_Medium"
            android:layout_width="48dp"
            android:layout_height="40dp"
            android:layout_marginTop="@dimen/spacing_4"
            android:background="@drawable/bg_answer_value"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvStudentAnswerLabel" />

        <TextView
            android:id="@+id/tvCorrectAnswer"
            style="@style/Text_Title_Medium"
            android:layout_width="48dp"
            android:layout_height="40dp"
            android:layout_marginStart="@dimen/spacing_8"
            android:background="@drawable/bg_answer_value"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/tvStudentAnswer"
            app:layout_constraintStart_toEndOf="@id/tvStudentAnswer"
            app:layout_constraintTop_toTopOf="@id/tvStudentAnswer" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
