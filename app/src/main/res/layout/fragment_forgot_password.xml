<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_24"
            android:paddingVertical="@dimen/spacing_48">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:src="@drawable/ic_chevron_left"
                app:tint="@color/text_primary" />

            <!-- Stepper -->
            <LinearLayout
                android:id="@+id/stepperContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_32"
                android:layout_marginBottom="@dimen/spacing_32"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/step1Indicator"
                    android:layout_width="@dimen/avatar_size_medium"
                    android:layout_height="@dimen/avatar_size_medium"
                    android:background="@drawable/bg_avatar"
                    android:backgroundTint="@color/primary"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="@color/on_primary"
                    android:textStyle="bold" />

                <View
                    android:id="@+id/divider1"
                    android:layout_width="@dimen/spacing_48"
                    android:layout_height="2dp"
                    android:layout_marginHorizontal="@dimen/spacing_8"
                    android:background="@color/surface_container_highest" />

                <TextView
                    android:id="@+id/step2Indicator"
                    android:layout_width="@dimen/avatar_size_medium"
                    android:layout_height="@dimen/avatar_size_medium"
                    android:background="@drawable/bg_avatar"
                    android:backgroundTint="@color/surface_container_highest"
                    android:gravity="center"
                    android:text="2"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold" />

                <View
                    android:id="@+id/divider2"
                    android:layout_width="@dimen/spacing_48"
                    android:layout_height="2dp"
                    android:layout_marginHorizontal="@dimen/spacing_8"
                    android:background="@color/surface_container_highest" />

                <TextView
                    android:id="@+id/step3Indicator"
                    android:layout_width="@dimen/avatar_size_medium"
                    android:layout_height="@dimen/avatar_size_medium"
                    android:background="@drawable/bg_avatar"
                    android:backgroundTint="@color/surface_container_highest"
                    android:gravity="center"
                    android:text="3"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Step 1: Email -->
            <LinearLayout
                android:id="@+id/step1Content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/forgot_password_title"
                    android:textAppearance="@style/Text_Headline_Small"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_4"
                    android:text="@string/forgot_password_subtitle"
                    android:textAppearance="@style/Text_Body_Medium"
                    android:textColor="@color/text_secondary" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEmail"
                    style="@style/Student.InputField"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_24"
                    app:hintEnabled="false"
                    app:startIconDrawable="@drawable/ic_email"
                    app:startIconTint="@color/text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="@dimen/spacing_16"
                        android:hint="@string/login_email_hint"
                        android:inputType="textEmailAddress"
                        android:textAppearance="@style/Text_Body_Large" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSendOTP"
                    style="@style/Student.PrimaryButton"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height_large"
                    android:layout_marginTop="@dimen/spacing_24"
                    android:text="@string/forgot_password_send_otp" />
            </LinearLayout>

            <!-- Step 2: OTP -->
            <LinearLayout
                android:id="@+id/step2Content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/forgot_password_otp_title"
                    android:textAppearance="@style/Text_Headline_Small"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_4"
                    android:text="@string/forgot_password_otp_subtitle"
                    android:textAppearance="@style/Text_Body_Medium"
                    android:textColor="@color/text_secondary" />

                <LinearLayout
                    android:id="@+id/otpContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_24"
                    android:gravity="center"
                    android:orientation="horizontal" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVerifyOTP"
                    style="@style/Student.PrimaryButton"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height_large"
                    android:layout_marginTop="@dimen/spacing_24"
                    android:text="@string/forgot_password_verify_otp" />
            </LinearLayout>

            <!-- Step 3: New Password -->
            <LinearLayout
                android:id="@+id/step3Content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/forgot_password_new_password_title"
                    android:textAppearance="@style/Text_Headline_Small"
                    android:textColor="@color/text_primary" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilNewPassword"
                    style="@style/Student.InputField"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_24"
                    app:hintEnabled="false"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNewPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="@dimen/spacing_16"
                        android:hint="@string/forgot_password_new_password_hint"
                        android:inputType="textPassword"
                        android:textAppearance="@style/Text_Body_Large" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilConfirmPassword"
                    style="@style/Student.InputField"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_16"
                    app:hintEnabled="false"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="@dimen/spacing_16"
                        android:hint="@string/forgot_password_confirm_password_hint"
                        android:inputType="textPassword"
                        android:textAppearance="@style/Text_Body_Large" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnResetPassword"
                    style="@style/Student.PrimaryButton"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height_large"
                    android:layout_marginTop="@dimen/spacing_24"
                    android:text="@string/forgot_password_reset_button" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/spacing_16"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
