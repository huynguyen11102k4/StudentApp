<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_close"
        app:navigationIconTint="@color/on_primary"
        app:title="@string/smart_review_title"
        app:titleTextColor="@color/on_primary"
        app:titleTextAppearance="@style/Text_Toolbar_Title_Bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_16">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/student_card_radius"
                app:cardElevation="@dimen/elevation_level2"
                app:strokeColor="@color/divider_soft"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_16">

                    <TextView
                        android:id="@+id/tvScore"
                        style="@style/Text_Headline_Medium"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/smart_review_detection_title"
                        android:textColor="@color/primary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvStudentName"
                        style="@style/Text_Body_Medium"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_12"
                        android:text="@string/smart_review_student_name_format"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvStudentCode"
                        style="@style/Text_Body_Medium"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_8"
                        android:text="@string/smart_review_student_code_format"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvClassCode"
                        style="@style/Text_Body_Medium"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_8"
                        android:text="@string/smart_review_class_code_format"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvExamCode"
                        style="@style/Text_Body_Medium"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_8"
                        android:text="@string/smart_review_exam_code_format"
                        android:textColor="@color/text_primary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_16"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/student_card_radius"
                app:cardElevation="@dimen/elevation_level2"
                app:strokeColor="@color/divider_soft"
                app:strokeWidth="1dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="320dp">

                    <ImageView
                        android:id="@+id/ivDebugImage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:contentDescription="@string/smart_review_image_description"
                        android:scaleType="fitCenter"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tvNoDebugImage"
                        style="@style/Text_Body_Medium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/smart_review_no_image"
                        android:textColor="@color/text_secondary" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/actionButtons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_16"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRetake"
                    style="@style/Student.OutlineButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height_large"
                    android:layout_marginEnd="@dimen/spacing_8"
                    android:layout_weight="1"
                    android:text="@string/smart_review_retake"
                    app:icon="@drawable/ic_camera"
                    app:iconGravity="textStart"
                    app:iconPadding="@dimen/spacing_8" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnContinueCapture"
                    style="@style/Student.PrimaryButton"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height_large"
                    android:layout_marginStart="@dimen/spacing_8"
                    android:layout_weight="1"
                    android:text="@string/smart_review_submit_action"
                    app:icon="@drawable/ic_check"
                    app:iconGravity="textStart"
                    app:iconPadding="@dimen/spacing_8" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDownloadImage"
                style="@style/Student.SecondaryButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height_large"
                android:layout_marginTop="@dimen/spacing_12"
                android:layout_marginBottom="@dimen/spacing_16"
                android:text="@string/smart_review_download_image"
                app:icon="@drawable/ic_download"
                app:iconGravity="textStart"
                app:iconPadding="@dimen/spacing_8" />
        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
