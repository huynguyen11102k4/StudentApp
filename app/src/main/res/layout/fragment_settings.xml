<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:paddingStart="@dimen/spacing_16"
        android:paddingEnd="@dimen/spacing_16"
        app:title="@string/settings_title"
        app:titleTextColor="@color/text_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:titleTextAppearance="@style/Text_Toolbar_Title_Bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                style="@style/Student.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_16"
                android:layout_marginTop="@dimen/spacing_16"
                app:contentPadding="@dimen/card_padding">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="@dimen/avatar_size_large"
                        android:layout_height="@dimen/avatar_size_large">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/ivProfileAvatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_avatar"
                            android:contentDescription="Ảnh đại diện"
                            android:scaleType="centerCrop"
                            android:visibility="gone"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

                        <TextView
                            android:id="@+id/tvProfileInitials"
                            style="@style/Text_Title_Large"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_avatar"
                            android:gravity="center"
                            android:text="HS"
                            android:textColor="@color/white"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_16"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvProfileName"
                            style="@style/Text_Title_Medium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Học sinh" />

                        <TextView
                            android:id="@+id/tvProfileEmail"
                            style="@style/Text_Body_Small"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_4"
                            android:text="email@example.com" />

                        <TextView
                            android:id="@+id/tvProfileRole"
                            style="@style/Text_Label_Small"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_6"
                            android:background="@drawable/bg_badge_neutral"
                            android:paddingHorizontal="@dimen/spacing_12"
                            android:paddingVertical="@dimen/spacing_4"
                            android:text="STUDENT"
                            android:textColor="@color/on_primary_container" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvSessionCount"
                style="@style/Text_Body_Small"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_24"
                android:layout_marginTop="@dimen/spacing_8"
                android:text="0 thiết bị đang đăng nhập"
                android:textColor="@color/text_secondary" />

            <!-- Group 1: Account & Display -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_24"
                android:layout_marginTop="@dimen/spacing_24"
                android:layout_marginBottom="@dimen/spacing_12"
                android:text="@string/settings_account_group"
                style="@style/Text_Title_Small" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_student_login_card"
                android:elevation="@dimen/elevation_level2"
                android:paddingVertical="@dimen/spacing_4"
                android:layout_marginHorizontal="@dimen/spacing_16">

                <!-- Account Item -->
                <LinearLayout
                    android:id="@+id/itemAccount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_16"
                    android:background="?android:attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="@dimen/avatar_size_medium"
                        android:layout_height="@dimen/avatar_size_medium"
                        android:background="@drawable/bg_icon_container_primary"
                        android:padding="@dimen/spacing_8"
                        android:src="@drawable/ic_user"
                        app:tint="@color/primary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_16"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_account"
                            style="@style/Text_Body_Large" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_account_desc"
                            style="@style/Text_Body_Small" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="@dimen/icon_size_large"
                        android:layout_height="@dimen/icon_size_large"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/outline_variant" />

                <LinearLayout
                    android:id="@+id/itemChangePassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_16"
                    android:background="?android:attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="@dimen/avatar_size_medium"
                        android:layout_height="@dimen/avatar_size_medium"
                        android:background="@drawable/bg_icon_container_primary"
                        android:padding="@dimen/spacing_8"
                        android:src="@drawable/ic_lock"
                        app:tint="@color/primary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_16"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_change_password"
                            style="@style/Text_Body_Large" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_change_password_desc"
                            style="@style/Text_Body_Small" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="@dimen/icon_size_large"
                        android:layout_height="@dimen/icon_size_large"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/outline_variant" />

                <!-- Dark Mode Item -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_16">

                    <ImageView
                        android:layout_width="@dimen/avatar_size_medium"
                        android:layout_height="@dimen/avatar_size_medium"
                        android:background="@drawable/bg_icon_container_primary"
                        android:padding="@dimen/spacing_8"
                        android:src="@drawable/ic_color_mode"
                        app:tint="@color/primary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_16"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_dark_mode"
                            style="@style/Text_Body_Large" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_dark_mode_desc"
                            style="@style/Text_Body_Small" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchDarkMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </LinearLayout>

            <!-- Group 2: Data -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_24"
                android:layout_marginTop="@dimen/spacing_24"
                android:layout_marginBottom="@dimen/spacing_12"
                android:text="@string/settings_data_group"
                style="@style/Text_Title_Small" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_student_login_card"
                android:elevation="@dimen/elevation_level2"
                android:paddingVertical="@dimen/spacing_4"
                android:layout_marginHorizontal="@dimen/spacing_16">

                <LinearLayout
                    android:id="@+id/itemStorage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_16"
                    android:background="?android:attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="@dimen/avatar_size_medium"
                        android:layout_height="@dimen/avatar_size_medium"
                        android:background="@drawable/bg_icon_container_secondary"
                        android:padding="@dimen/spacing_8"
                        android:src="@drawable/ic_storage"
                        app:tint="@color/primary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_16"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_storage"
                            style="@style/Text_Body_Large" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_storage_desc"
                            style="@style/Text_Body_Small" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="@dimen/icon_size_large"
                        android:layout_height="@dimen/icon_size_large"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/outline_variant" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_16">

                    <ImageView
                        android:layout_width="@dimen/avatar_size_medium"
                        android:layout_height="@dimen/avatar_size_medium"
                        android:background="@drawable/bg_icon_container_secondary"
                        android:padding="@dimen/spacing_8"
                        android:src="@drawable/ic_notification"
                        app:tint="@color/primary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_16"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_notifications"
                            style="@style/Text_Body_Large" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_notifications_desc"
                            style="@style/Text_Body_Small" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchNotifications"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>
            </LinearLayout>

            <!-- Group 3: Other -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_24"
                android:layout_marginTop="@dimen/spacing_24"
                android:layout_marginBottom="@dimen/spacing_12"
                android:text="@string/settings_other_group"
                style="@style/Text_Title_Small" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_student_login_card"
                android:elevation="@dimen/elevation_level2"
                android:paddingVertical="@dimen/spacing_4"
                android:layout_marginHorizontal="@dimen/spacing_16">

                <LinearLayout
                    android:id="@+id/itemHelp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_16"
                    android:background="?android:attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="@dimen/avatar_size_medium"
                        android:layout_height="@dimen/avatar_size_medium"
                        android:background="@drawable/bg_icon_container_tertiary"
                        android:padding="@dimen/spacing_8"
                        android:src="@drawable/ic_notification"
                        app:tint="@color/primary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_16"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_help"
                            style="@style/Text_Body_Large" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_help_desc"
                            style="@style/Text_Body_Small" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="@dimen/icon_size_large"
                        android:layout_height="@dimen/icon_size_large"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>
            </LinearLayout>

            <!-- Logout -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/Student.OutlineButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_margin="@dimen/spacing_24"
                android:text="@string/settings_logout"
                android:textColor="@color/error"
                app:strokeColor="@color/error" />

            <!-- Version -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_32"
                android:gravity="center"
                android:text="@string/settings_version"
                style="@style/Text_Label_Small" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
