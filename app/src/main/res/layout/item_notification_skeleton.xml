<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_12"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="@dimen/student_card_radius"
    app:cardElevation="@dimen/elevation_level0"
    app:contentPadding="@dimen/spacing_12"
    app:strokeColor="@color/divider_soft"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:alpha="0.9"
        android:gravity="top"
        android:orientation="horizontal">

        <View
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="@dimen/spacing_12"
            android:background="@drawable/bg_notification_skeleton" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <View
                android:layout_width="168dp"
                android:layout_height="14dp"
                android:background="@drawable/bg_notification_skeleton" />

            <View
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_marginTop="@dimen/spacing_10"
                android:background="@drawable/bg_notification_skeleton" />

            <View
                android:layout_width="220dp"
                android:layout_height="12dp"
                android:layout_marginTop="@dimen/spacing_6"
                android:background="@drawable/bg_notification_skeleton" />

            <View
                android:layout_width="96dp"
                android:layout_height="12dp"
                android:layout_marginTop="@dimen/spacing_12"
                android:background="@drawable/bg_notification_skeleton" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
