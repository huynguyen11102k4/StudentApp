<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Student.DashboardCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_12"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/surface"
    app:contentPadding="@dimen/spacing_16">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="@dimen/icon_container_size"
                android:layout_height="@dimen/icon_container_size"
                android:background="@drawable/bg_icon_container_secondary">

                <ImageView
                    android:layout_width="@dimen/icon_size_large"
                    android:layout_height="@dimen/icon_size_large"
                    android:layout_gravity="center"
                    android:contentDescription="@string/dashboard_bottom_classes"
                    android:src="@drawable/ic_users"
                    app:tint="@color/tertiary" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_16"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvClassName"
                    style="@style/Text_Title_Medium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/class_list_sample_name" />

                <TextView
                    android:id="@+id/tvSubject"
                    style="@style/Text_Body_Small"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_4"
                    android:text="@string/class_list_sample_subject" />

                <TextView
                    android:id="@+id/tvLeaveRequestedBadge"
                    style="@style/Text_Label_Small"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_8"
                    android:background="@drawable/bg_badge_review"
                    android:maxLines="1"
                    android:text="@string/class_list_leave_requested_badge"
                    android:textColor="@color/status_review_text"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvStudentCount"
                style="@style/Text_Label_Small"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_processing"
                android:maxLines="1"
                android:paddingHorizontal="@dimen/spacing_12"
                android:paddingVertical="@dimen/spacing_4"
                android:text="@string/class_list_student_count_sample"
                android:textColor="@color/status_processing_text" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                style="@style/Text_Label_Medium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/class_detail_student_list" />

            <ImageView
                android:layout_width="@dimen/icon_size_large"
                android:layout_height="@dimen/icon_size_large"
                android:layout_marginStart="@dimen/spacing_8"
                android:contentDescription="@string/common_confirm"
                android:src="@drawable/ic_chevron_right"
                app:tint="@color/text_secondary" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
