<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/inverse_surface">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:scaleType="fitCenter" />

    <View
        android:id="@+id/scanOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="@dimen/scan_overlay_margin"
        android:background="@drawable/bg_scan_overlay"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnClose"
        android:layout_width="@dimen/spacing_48"
        android:layout_height="@dimen/spacing_48"
        android:layout_margin="@dimen/spacing_16"
        android:background="@drawable/bg_chip_glass"
        android:contentDescription="@string/camera_ar_close"
        android:padding="@dimen/spacing_12"
        android:src="@drawable/ic_close"
        app:tint="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/topInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_16"
        android:layout_marginTop="@dimen/spacing_16"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvMarkerStatus"
            style="@style/Text_Label_Medium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_processing"
            android:gravity="center"
            android:paddingHorizontal="@dimen/spacing_16"
            android:paddingVertical="@dimen/spacing_8"
            android:text="@string/camera_ar_marker_hint"
            android:textColor="@color/status_processing_text"
            android:fontFamily="@font/outfit"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvInstruction"
            style="@style/Text_Body_Small"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_8"
            android:background="@drawable/bg_chip_glass"
            android:gravity="center"
            android:paddingHorizontal="@dimen/spacing_16"
            android:paddingVertical="@dimen/spacing_8"
            android:text="@string/camera_ar_instruction"
            android:fontFamily="@font/outfit"
            android:textColor="@color/white" />
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabCapture"
        style="@style/Widget.Material3.FloatingActionButton.Large.Primary"
        android:layout_width="@dimen/camera_capture_button_size"
        android:layout_height="@dimen/camera_capture_button_size"
        android:layout_marginBottom="@dimen/spacing_32"
        android:contentDescription="@string/camera_ar_capture"
        android:src="@drawable/ic_camera"
        app:backgroundTint="@color/primary"
        app:fabCustomSize="@dimen/camera_capture_button_size"
        app:maxImageSize="@dimen/camera_capture_icon_size"
        app:tint="@color/on_primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/btnFlash"
        android:layout_width="@dimen/spacing_56"
        android:layout_height="@dimen/spacing_56"
        android:layout_marginStart="@dimen/spacing_24"
        android:background="@drawable/bg_icon_container_primary"
        android:contentDescription="@string/camera_ar_flash_off"
        android:padding="@dimen/spacing_12"
        android:src="@drawable/ic_flash_off"
        app:tint="@color/primary"
        app:layout_constraintBottom_toBottomOf="@id/fabCapture"
        app:layout_constraintStart_toEndOf="@id/fabCapture"
        app:layout_constraintTop_toTopOf="@id/fabCapture" />

    <FrameLayout
        android:id="@+id/progressOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/scrim"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/student_card_radius_large"
            app:contentPadding="@dimen/spacing_24">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:layout_width="@dimen/spacing_48"
                    android:layout_height="@dimen/spacing_48"
                    android:indeterminate="true"
                    app:indicatorColor="@color/primary" />

                <TextView
                    android:id="@+id/tvProgressMessage"
                    style="@style/Text_Body_Medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_12"
                    android:text="@string/camera_ar_processing"
                    android:textColor="@color/text_primary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
