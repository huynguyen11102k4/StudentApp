<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/inverse_surface">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:scaleType="fitCenter" />

    <View
        android:id="@+id/scanOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="@dimen/scan_overlay_margin"
        android:background="@drawable/bg_scan_overlay"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnClose"
        android:layout_width="@dimen/spacing_48"
        android:layout_height="@dimen/spacing_48"
        android:layout_margin="@dimen/spacing_16"
        android:background="@drawable/bg_chip_glass"
        android:contentDescription="@string/camera_ar_close"
        android:padding="@dimen/spacing_12"
        android:src="@drawable/ic_close"
        android:tint="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/topInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_16"
        android:layout_marginTop="@dimen/spacing_16"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvMarkerStatus"
            style="@style/Text_Label_Medium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_processing"
            android:gravity="center"
            android:paddingHorizontal="@dimen/spacing_16"
            android:paddingVertical="@dimen/spacing_8"
            android:text="@string/camera_ar_marker_hint"
            android:textColor="@color/status_processing_text"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvInstruction"
            style="@style/Text_Body_Small"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_8"
            android:background="@drawable/bg_chip_glass"
            android:gravity="center"
            android:paddingHorizontal="@dimen/spacing_16"
            android:paddingVertical="@dimen/spacing_8"
            android:text="@string/camera_ar_instruction"
            android:textColor="@color/white" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomControlsCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_32"
        app:cardBackgroundColor="@color/inverse_surface"
        app:cardCornerRadius="@dimen/student_card_radius_xlarge"
        app:cardElevation="@dimen/elevation_level3"
        app:contentPadding="@dimen/spacing_12"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeWidth="0dp">

        <LinearLayout
            android:id="@+id/bottomControls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnGallery"
                android:layout_width="@dimen/spacing_56"
                android:layout_height="@dimen/spacing_56"
                android:background="@drawable/bg_icon_container_secondary"
                android:contentDescription="@string/camera_ar_gallery"
                android:padding="@dimen/spacing_12"
                android:src="@drawable/ic_assignment"
                android:tint="@color/tertiary" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabCapture"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_24"
                android:contentDescription="@string/camera_ar_capture"
                android:src="@drawable/ic_camera"
                app:backgroundTint="@color/primary"
                app:fabSize="normal"
                app:tint="@color/on_primary" />

            <ImageButton
                android:id="@+id/btnFlash"
                android:layout_width="@dimen/spacing_56"
                android:layout_height="@dimen/spacing_56"
                android:background="@drawable/bg_icon_container_primary"
                android:contentDescription="@string/camera_ar_flash_off"
                android:padding="@dimen/spacing_12"
                android:src="@drawable/ic_flash_off"
                android:tint="@color/primary" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <FrameLayout
        android:id="@+id/progressOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/scrim"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:cardBackgroundColor="@color/inverse_surface"
            app:cardCornerRadius="@dimen/student_card_radius_large"
            app:contentPadding="@dimen/spacing_24">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:layout_width="@dimen/spacing_48"
                    android:layout_height="@dimen/spacing_48"
                    android:indeterminate="true"
                    app:indicatorColor="@color/white" />

                <TextView
                    android:id="@+id/tvProgressMessage"
                    style="@style/Text_Body_Medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_12"
                    android:text="@string/camera_ar_processing"
                    android:textColor="@color/white" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
