<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        app:elevation="@dimen/elevation_level0">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            android:paddingStart="@dimen/spacing_16"
            android:paddingEnd="@dimen/spacing_16"
            app:title="@string/class_list_title"
            app:titleTextColor="@color/text_primary"
        app:titleTextAppearance="@style/Text_Toolbar_Title_Bold" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilSearch"
            style="@style/Student.InputField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/spacing_16"
            android:layout_marginBottom="@dimen/spacing_12"
            app:startIconDrawable="@drawable/ic_search"
            app:startIconTint="@color/text_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/class_list_search_hint"
                android:inputType="text"
                android:maxLines="1"
                android:textAppearance="@style/Text_Body_Large" />
        </com.google.android.material.textfield.TextInputLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_16"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/headerRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_16"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvClassCount"
                style="@style/Text_Body_Small"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/class_list_title"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvClasses"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/spacing_8"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/screen_bottom_content_padding" />

        <include
            android:id="@+id/loadingSkeleton"
            android:layout_marginTop="@dimen/spacing_8"
            layout="@layout/layout_skeleton_list" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/spacing_32"
        android:visibility="gone"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <FrameLayout
            android:layout_width="@dimen/spacing_80"
            android:layout_height="@dimen/spacing_80"
            android:background="@drawable/bg_icon_container_primary">

            <ImageView
                android:layout_width="@dimen/icon_size_xlarge"
                android:layout_height="@dimen/icon_size_xlarge"
                android:layout_gravity="center"
                android:contentDescription="@string/class_list_empty_title"
                android:src="@drawable/ic_users"
                app:tint="@color/primary" />
        </FrameLayout>

        <TextView
            style="@style/Text_Title_Medium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_16"
            android:text="@string/class_list_empty_title" />

        <TextView
            style="@style/Text_Body_Medium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_8"
            android:gravity="center"
            android:text="@string/class_list_empty_subtitle"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabJoinClass"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/fab_margin"
        android:contentDescription="@string/student_join_class_action"
        android:text="@string/student_join_class_action"
        app:backgroundTint="@color/primary"
        app:icon="@drawable/ic_plus"
        app:iconTint="@color/on_primary"
        app:tint="@color/on_primary" />

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        app:indicatorColor="@color/primary" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
