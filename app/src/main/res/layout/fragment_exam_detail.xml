<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        app:elevation="@dimen/elevation_level0">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            app:navigationIcon="@drawable/ic_chevron_left"
            app:navigationIconTint="@color/text_primary"
            app:title="@string/exam_detail_title"
            app:titleTextColor="@color/text_primary"
        app:titleTextAppearance="@style/Text_Toolbar_Title_Bold" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/spacing_32"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_16">

            <TextView
                android:id="@+id/tvExamName"
                style="@style/Text_Title_Large"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/exam_detail_title" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_8"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvSubject"
                    style="@style/Text_Label_Small"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    style="@style/Text_Label_Small"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/spacing_8"
                    android:text="@string/common_separator_dot" />

                <TextView
                    android:id="@+id/tvDuration"
                    style="@style/Text_Label_Small"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    style="@style/Text_Label_Small"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/spacing_8"
                    android:text="@string/common_separator_dot" />

                <TextView
                    android:id="@+id/tvQuestionCount"
                    style="@style/Text_Label_Small"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                style="@style/Student.DashboardCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_16"
                app:cardBackgroundColor="@color/surface"
                app:contentPadding="@dimen/spacing_16">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Text_Label_Medium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/exam_detail_info" />

                    <TextView
                        android:id="@+id/tvStatus"
                        style="@style/Text_Label_Small"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_8"
                        android:background="@drawable/bg_badge_processing"
                        android:paddingHorizontal="@dimen/spacing_12"
                        android:paddingVertical="@dimen/spacing_4"
                        android:textColor="@color/status_processing_text" />

                    <TextView
                        android:id="@+id/tvExamType"
                        style="@style/Text_Body_Small"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_8" />

                    <TextView
                        android:id="@+id/tvGradingType"
                        style="@style/Text_Body_Small"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_4" />

                    <TextView
                        android:id="@+id/tvTemplateName"
                        style="@style/Text_Body_Small"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_4" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPendingAppeals"
                style="@style/Student.DashboardCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_16"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"
                app:cardBackgroundColor="@color/surface"
                app:contentPadding="@dimen/spacing_16">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/icon_container_size"
                        android:layout_height="@dimen/icon_container_size"
                        android:background="@drawable/bg_icon_container_tertiary"
                        android:contentDescription="@string/appeals_list_title"
                        android:padding="@dimen/spacing_12"
                        android:src="@drawable/ic_appeal"
                        app:tint="@color/tertiary" />

                    <TextView
                        android:id="@+id/tvPendingAppeals"
                        style="@style/Text_Body_Medium"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_12"
                        android:layout_weight="1" />

                    <ImageView
                        android:layout_width="@dimen/icon_size_large"
                        android:layout_height="@dimen/icon_size_large"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardOfflineAlert"
                style="@style/Student.DashboardCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_16"
                app:cardBackgroundColor="@color/tertiary_container"
                app:contentPadding="@dimen/spacing_16">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Text_Body_Medium"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/exam_detail_need_template_data" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDownloadOffline"
                        style="@style/Student.PrimaryButton"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height_large"
                        android:layout_marginTop="@dimen/spacing_12"
                        android:text="@string/exam_detail_download_template"
                        app:icon="@drawable/ic_download" />

                    <TextView
                        android:id="@+id/tvDownloadStatus"
                        style="@style/Text_Body_Small"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_8"
                        android:visibility="gone" />

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressDownload"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_8"
                        android:indeterminate="true"
                        android:visibility="gone"
                        app:indicatorColor="@color/primary"
                        app:trackColor="@color/surface_variant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartScanning"
                style="@style/Student.PrimaryButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height_large"
                android:layout_marginTop="@dimen/spacing_24"
                android:text="@string/exam_detail_start_scanning"
                app:icon="@drawable/ic_camera" />

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/spacing_16"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
