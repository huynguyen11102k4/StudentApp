<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurfaceDim">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:elevation="@dimen/elevation_level1">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/spacing_16"
            android:paddingEnd="@dimen/spacing_8"
            app:contentInsetEnd="0dp"
            app:contentInsetStart="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="@dimen/avatar_size_medium"
                    android:layout_height="@dimen/avatar_size_medium">

                    <ImageView
                        android:id="@+id/ivStudentAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_avatar"
                        android:contentDescription="@string/settings_account"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tvStudentInitials"
                        style="@style/Text_Label_Small"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_avatar"
                        android:gravity="center"
                        android:textColor="@color/on_primary"
                        android:textStyle="bold"
                        tools:text="HS" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvStudentName"
                    style="@style/Text_Title_Large"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_12"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="@string/dashboard_title_student"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btnNotifications"
                    android:layout_width="@dimen/spacing_48"
                    android:layout_height="@dimen/spacing_48"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/notifications_title"
                    android:src="@drawable/ic_notification"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <ImageButton
                    android:id="@+id/btnSettings"
                    android:layout_width="@dimen/spacing_48"
                    android:layout_height="@dimen/spacing_48"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/settings_title"
                    android:src="@drawable/ic_settings"
                    app:tint="?attr/colorOnSurfaceVariant" />
            </LinearLayout>
        </com.google.android.material.appbar.MaterialToolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_16"
            android:paddingBottom="@dimen/spacing_112">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardOnline"
                    style="@style/Student.DashboardActionCard"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="@dimen/spacing_6"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/primary_container">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/dashboard_quick_card_min_height"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_16">

                        <FrameLayout
                            android:layout_width="@dimen/icon_container_size"
                            android:layout_height="@dimen/icon_container_size"
                            android:background="@drawable/bg_icon_container_primary">

                            <ImageView
                                android:layout_width="@dimen/icon_size_large"
                                android:layout_height="@dimen/icon_size_large"
                                android:layout_gravity="center"
                                android:contentDescription="@string/dashboard_exam_student_title"
                                android:src="@drawable/ic_assignment"
                                app:tint="@color/on_primary_container" />
                        </FrameLayout>

                        <TextView
                            style="@style/Text_Title_Medium"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_16"
                            android:text="@string/dashboard_exam_student_title"
                            android:textColor="@color/on_primary_container" />

                        <TextView
                            style="@style/Text_Body_Small"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_4"
                            android:text="@string/dashboard_exam_student_subtitle"
                            android:textColor="@color/on_primary_container" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardClasses"
                    style="@style/Student.DashboardActionCard"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="@dimen/spacing_6"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/tertiary_container">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/dashboard_quick_card_min_height"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_16">

                        <FrameLayout
                            android:layout_width="@dimen/icon_container_size"
                            android:layout_height="@dimen/icon_container_size"
                            android:background="@drawable/bg_icon_container_tertiary">

                            <ImageView
                                android:layout_width="@dimen/icon_size_large"
                                android:layout_height="@dimen/icon_size_large"
                                android:layout_gravity="center"
                                android:contentDescription="@string/dashboard_classes_title"
                                android:src="@drawable/ic_users"
                                app:tint="@color/on_tertiary_container" />
                        </FrameLayout>

                        <TextView
                            style="@style/Text_Title_Medium"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_16"
                            android:text="@string/dashboard_classes_title"
                            android:textColor="@color/on_tertiary_container" />

                        <TextView
                            android:id="@+id/tvClassSummary"
                            style="@style/Text_Body_Small"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_4"
                            android:textColor="@color/on_tertiary_container"
                            tools:text="2 lớp đã tham gia" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResults"
                style="@style/Student.SecondaryButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height_large"
                android:layout_marginTop="@dimen/spacing_12"
                android:text="@string/dashboard_results_action"
                app:icon="@drawable/ic_check"
                app:iconGravity="textStart"
                app:iconPadding="@dimen/spacing_8" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_24"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/Text_Title_Large"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/dashboard_recent_exams" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewAllExams"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/button_height"
                    android:text="@string/dashboard_view_all" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecentExams"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_8"
                android:nestedScrollingEnabled="false"
                tools:itemCount="3"
                tools:listitem="@layout/item_exam" />

            <include
                android:id="@+id/loadingSkeletonRecentExams"
                android:layout_marginTop="@dimen/spacing_8"
                layout="@layout/layout_skeleton_list" />

            <LinearLayout
                android:id="@+id/emptyRecentExams"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_12"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_24"
                android:visibility="gone">

                <ImageView
                    android:layout_width="@dimen/avatar_size_large"
                    android:layout_height="@dimen/avatar_size_large"
                    android:background="@drawable/bg_icon_container_primary"
                    android:contentDescription="@string/dashboard_empty_title"
                    android:padding="@dimen/spacing_20"
                    android:src="@drawable/ic_assignment"
                    app:tint="@color/on_primary_container" />

                <TextView
                    style="@style/Text_Title_Medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_16"
                    android:text="@string/dashboard_empty_title" />

                <TextView
                    style="@style/Text_Body_Small"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_4"
                    android:gravity="center"
                    android:text="@string/dashboard_empty_subtitle" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
